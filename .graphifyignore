# Patterns for graphify to skip when building the knowledge graph.
# Same syntax as .gitignore.

# Dependencies + build output — not meaningful to the architecture graph
node_modules/
.pnpm-store/
.turbo/
.next/
dist/
build/
coverage/

# Move build artefacts and .move compiler cache
packages/contracts/build/
.minitia/
.move/

# VCS + local config
.git/
.vscode/
.idea/

# Env / secrets / logs — never include
.env
.env.*
!.env.example
*.log

# Lockfiles — noise, not structure
pnpm-lock.yaml
package-lock.json
yarn.lock

# Pre-existing generated outputs
docs/architecture-graph/

# Generated code
*.d.ts.map
*.js.map

# Editor temp
*.swp
*~
.DS_Store
