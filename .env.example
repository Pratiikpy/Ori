# ============================
# Ori — Environment Variables
# ============================
# Copy to .env (never commit .env).
#
# Grouping:
#   [REQUIRED]  — apps crash at boot if missing.
#   [OPTIONAL]  — sane defaults exist in code.
#   [DEV-ONLY]  — local-only values, replaced in prod.

# ============================
# [REQUIRED] Network selection
# ============================
NETWORK=testnet                          # testnet | mainnet
CHAIN_ID=ori-1                           # Your rollup chain ID (testnet)
MAINNET_CHAIN_ID=interwoven-1            # Initia L1 mainnet

# Initia L1 (for .init username resolution)
L1_CHAIN_ID=initiation-2                 # Initia L1 testnet
L1_RPC_URL=https://rpc.testnet.initia.xyz
L1_REST_URL=https://rest.testnet.initia.xyz
L1_USERNAMES_MODULE=0x42cd8467b1c86e59bf319e5664a09b6b5840bb3fac64f5ce690b5041c530565a

# Ori rollup (local dev)
ORI_RPC_URL=http://localhost:26657
ORI_REST_URL=http://localhost:1317
ORI_INDEXER_URL=http://localhost:8080
ORI_NATIVE_DENOM=umin
ORI_NATIVE_SYMBOL=INIT
ORI_NATIVE_DECIMALS=6

# Deployed contracts (fill after deploy)
ORI_MODULE_ADDRESS=                      # Your Gas Station hex address (0x...)

# Backend
API_URL=http://localhost:3001
DATABASE_URL=postgresql://ori:ori@localhost:5432/ori
REDIS_URL=redis://localhost:6379
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_this_is_dev_only_32_chars_min
VAPID_PUBLIC_KEY=                        # generate with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@ori.chat

# Frontend (Next.js needs NEXT_PUBLIC_ prefix for client-side)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_CHAIN_ID=ori-1
NEXT_PUBLIC_RPC_URL=http://localhost:26657
NEXT_PUBLIC_REST_URL=http://localhost:1317
NEXT_PUBLIC_JSON_RPC_URL=http://localhost:8545
NEXT_PUBLIC_NATIVE_DENOM=umin
NEXT_PUBLIC_NATIVE_SYMBOL=INIT
NEXT_PUBLIC_NATIVE_DECIMALS=6
NEXT_PUBLIC_ORI_MODULE_ADDRESS=
NEXT_PUBLIC_BRIDGE_SRC_CHAIN_ID=initiation-2
NEXT_PUBLIC_BRIDGE_SRC_DENOM=uinit
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Privy for social login (get from https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional: Sentry for error tracking
SENTRY_DSN=

# ============================
# New in v2
# ============================

# Privy embedded-wallet signature compatibility (matches iUSD Pay mainnet).
# Set to "false" in production once Privy fixes their EIP-191 recovery bug.
PRIVY_COMPAT=true

# Rate limit tiers (requests per minute)
RATE_LIMIT_GLOBAL_MAX=600
RATE_LIMIT_MESSAGES_MAX=120
RATE_LIMIT_AUTH_MAX=30

# Achievement issuer — 12/24-word BIP-39 mnemonic for a funded backend wallet.
# Leave empty to disable auto-mint. Required for first-payment / first-tip badges.
BADGE_ISSUER_MNEMONIC=

# Gas denom used by the issuer when submitting Move txs. Typically same as
# ORI_NATIVE_DENOM.
ISSUER_GAS_DENOM=umin

# Sponsored onboarding — the backend pays small grants on behalf of new users
# so first-time setup doesn't require a faucet visit. Reuses BADGE_ISSUER_MNEMONIC
# as the paying signer. SAFE on testnet (gas is free); flip SPONSOR_ENABLED=false
# on mainnet launch until the signer is funded and you're comfortable with the
# daily budget cap.
#   SPONSOR_SEED_AMOUNT_UMIN    : B4 — tiny INIT grant to new users (0.01 INIT)
#   SPONSOR_USERNAME_FEE_UMIN   : B5 — covers .init registration fee (0.5 INIT)
#   SPONSOR_DAILY_BUDGET_UMIN   : hard cap per UTC day across both grants (5 INIT)
#   SPONSOR_PER_IP_COOLDOWN_HOURS: blocks drain loops per IP (24h)
SPONSOR_ENABLED=true
SPONSOR_SEED_AMOUNT_UMIN=10000
SPONSOR_USERNAME_FEE_UMIN=500000
SPONSOR_DAILY_BUDGET_UMIN=5000000
SPONSOR_PER_IP_COOLDOWN_HOURS=24

# A2A JSON-RPC server for the MCP+A2A dual-dialect agent surface. Leave unset
# to run the MCP server as stdio-only (Claude Desktop). Setting this enables
# the HTTP JSON-RPC 2.0 endpoint used by non-MCP agent frameworks.
ORI_A2A_PORT=3030

# L1 endpoints the frontend uses to resolve .init → address (usernames module).
NEXT_PUBLIC_L1_CHAIN_ID=initiation-2
NEXT_PUBLIC_L1_REST_URL=https://rest.testnet.initia.xyz
