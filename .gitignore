# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ─── Local design-handoff reference (zip extract, not for repo) ─────────────
design_ref/

# ─── Build artifacts ────────────────────────────────────────────────────────
dist/
build/
.next/
.turbo/
out/
*.tsbuildinfo

# Move build artifacts
artifacts/

# ─── Env & secrets ──────────────────────────────────────────────────────────
.env
.env.*
*.env
.env.local
.env.*.local
.env.production
.env.vercel
.credentials
credentials.json

# ...keep example templates checked in
!.env.example
!.env.production.example
!.env.*.example

# ─── Keys (NEVER commit) ────────────────────────────────────────────────────
*.pem
*.key
deployer-key.json
# BIP-39 test wallets (testnet only, still private)
.ori-*-wallets.json
apps/*/.ori-*-wallets.json
**/.ori-*-wallets.json

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── IDE / OS ───────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
.DS_Store
Thumbs.db

# ─── Deployment ─────────────────────────────────────────────────────────────
.vercel

# ─── Testing ────────────────────────────────────────────────────────────────
coverage/

# ─── graphify ───────────────────────────────────────────────────────────────
# CLI writes to ./graphify-out/ by default; we sync to docs/architecture-graph/
# via scripts/update-graph.sh, so the raw output directory is disposable.
graphify-out/
docs/architecture-graph/cache/

# ─── Personal / auto-generated tooling that doesn't belong on GitHub ────────
# Local dev tooling (emergent.sh agent runner) and per-machine git config —
# these were accidentally tracked early on. Now ignored going forward.
.emergent/
.gitconfig

# Editor-specific config — Claude Code settings.json was per-machine state
# only. Each contributor sets their own preferences.
.claude/

# Internal planning docs and ephemeral test reports written by automation.
# Not part of the project source; kept out of the public repo.
memory/
test_reports/

# Internal-only design assets, planning markdowns, and deployment notes
# (DEPLOY.md / DEPLOY2.md) that don't help anyone reading the repo
# externally. The product README + .initia/submission.json cover the
# externally relevant info.
design-refs/
DEPLOY.md
DEPLOY2.md
CONTRIBUTING.md
CLAUDE.md
.graphifyignore
.mcp.json.sample
compose.yaml

# Internal docs that previously lived in docs/ and were superseded by the
# README + the live deployment.
docs/RUNBOOK.md
docs/MAINNET_DEPLOY.md
docs/MIGRATION_PLAN.md
docs/SHIPMENT1_PLAN.md
docs/SHIPMENT2_PLAN.md
docs/DEPLOY_TO_VERCEL.md
docs/DAY_1_SETUP.md

# Auto-generated design tokens / planning artifacts that aren't imported by
# any code in apps/ or packages/. Real design system lives in code (Tailwind
# theme + apps/web/src/app/globals.css).
design_guidelines.json

# Example env files contained in the previous commits as `.env.example` and
# `.env.production.example` are now removed — the README documents the
# required env vars by name; concrete values live only in the deployer's
# private store and never in the repo.
.env.example
.env.production.example

# One-shot debugging scripts. Long-lived maintenance scripts stay tracked
# under scripts/; these patterns catch the throwaway ones.
scripts/debug-*.mjs
scripts/debug-*.sh
