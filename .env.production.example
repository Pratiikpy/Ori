# ─────────────────────────────────────────────────────────────────────────
# ORI — production env vars
#
# Copy each value from the source listed below into Vercel's "Environment
# Variables" panel under Project Settings → Environment Variables. Do NOT
# commit a real .env file.
#
# Everything here is required UNLESS marked optional. Missing required vars
# cause the API to exit at startup (Zod validation in apps/api/src/config.ts).
# ─────────────────────────────────────────────────────────────────────────


# ─── Core runtime ─────────────────────────────────────────────────────────

NODE_ENV=production
LOG_LEVEL=info


# ─── CORS ─────────────────────────────────────────────────────────────────

# Your deployed Vercel URL(s). Multiple origins comma-separated.
# Example: https://ori.chat,https://www.ori.chat,https://<project>.vercel.app
CORS_ORIGINS=https://<your-vercel-domain>


# ─── Postgres (Supabase) ──────────────────────────────────────────────────
#
# Supabase gives you TWO URLs in Project Settings → Database:
#   1. "Connection string" (port 5432)      → direct, for migrations only
#   2. "Connection pooling" (port 6543)     → pooled, for serverless runtime
#
# ALWAYS use the POOLED URL at runtime on Vercel. Serverless invocations
# open many parallel connections — the pooler multiplexes them onto a small
# number of real Postgres sockets. Using the direct URL will exhaust
# Supabase's ~60-connection free-tier cap within seconds of traffic.
#
# For Prisma specifically, append these two query params to the pooled URL
# so Prisma sends prepared-statement-free queries that pgbouncer accepts:
#     ?pgbouncer=true&connection_limit=1
#
# Runtime (Vercel functions):
DATABASE_URL=postgres://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Migrations only (run locally with `pnpm --filter @ori/api db:migrate:deploy`).
# Never paste this into Vercel — it's strictly for admin work from your laptop.
DIRECT_DATABASE_URL=postgres://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres


# ─── Redis (Upstash) ──────────────────────────────────────────────────────
#
# Create via Vercel Marketplace → Upstash for Redis → add to project. That
# auto-injects UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN. We don't
# use REST — we use ioredis over TCP+TLS. Get the rediss:// URL from the
# Upstash dashboard "Details" tab → "TCP/TLS" section.

REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379


# ─── Auth ────────────────────────────────────────────────────────────────

# Generate fresh for production: `openssl rand -hex 32`. Never reuse dev key.
JWT_SECRET=<paste a 32-byte hex string here>
SESSION_TTL_HOURS=720


# ─── Initia chain config ─────────────────────────────────────────────────

CHAIN_ID=ori-1
# For Shipment 1, these can stay pointing at your local rollup — the event
# listener isn't running in prod yet (Shipment 2). Move actions from the web
# app still go chain-direct via InterwovenKit, which uses the RPC URL on the
# client. For production, point these at a publicly-reachable rollup URL.
ORI_RPC_URL=https://<your-rollup-rpc>
ORI_REST_URL=https://<your-rollup-rest>
ORI_MODULE_ADDRESS=0x05dd0c60873d4d93658d5144fd0615bcfa43a53a


# ─── Initia L1 (.init usernames) ─────────────────────────────────────────

L1_CHAIN_ID=initiation-2
L1_REST_URL=https://rest.testnet.initia.xyz
L1_USERNAMES_MODULE=0x42cd8467b1c86e59bf319e5664a09b6b5840bb3fac64f5ce690b5041c530565a


# ─── Web push (VAPID) ────────────────────────────────────────────────────
#
# Generate locally: `npx web-push generate-vapid-keys`. Keep the private key
# SECRET. For Shipment 1 these are required by config validation even though
# push delivery runs in Shipment 2; placeholders are fine as long as they
# parse.

VAPID_PUBLIC_KEY=<base64url public>
VAPID_PRIVATE_KEY=<base64url private>
VAPID_SUBJECT=mailto:admin@yourdomain.com


# ─── Badge issuer (optional, Shipment 2) ─────────────────────────────────
# Leave blank on Shipment 1 — badge auto-mint runs in the Edge Function,
# not in the API. The API still boots fine with this empty.
# BADGE_ISSUER_MNEMONIC="24 or 12 word bip-39 mnemonic"


# ─── Privy embedded-wallet compatibility ─────────────────────────────────
# Keep at 'true' in prod ONLY if you accept the nonce-bound signature-mismatch
# bypass for Privy embedded wallets. Single-use nonces mean this is safe,
# but read the comment in apps/api/src/lib/verifySignature.ts before flipping.
PRIVY_COMPAT=true


# ─── Rate limits ─────────────────────────────────────────────────────────

RATE_LIMIT_GLOBAL_MAX=600
RATE_LIMIT_MESSAGES_MAX=120
RATE_LIMIT_AUTH_MAX=30


# ─── Sponsored onboarding ───────────────────────────────────────────────

SPONSOR_ENABLED=true
SPONSOR_SEED_AMOUNT_UMIN=10000
SPONSOR_USERNAME_FEE_UMIN=500000
SPONSOR_DAILY_BUDGET_UMIN=5000000
SPONSOR_PER_IP_COOLDOWN_HOURS=24


# ─── Public base URL ─────────────────────────────────────────────────────

PUBLIC_API_URL=https://<your-vercel-domain>/api


# ─────────────────────────────────────────────────────────────────────────
# WEB (NEXT_PUBLIC_*) — vars the browser bundles need
# ─────────────────────────────────────────────────────────────────────────

# Same-origin API on Vercel. In local dev the web's .env.local should set
# this to http://localhost:3001 instead (standalone Fastify on :3001).
NEXT_PUBLIC_API_URL=/api

# ─── Supabase Realtime (Shipment 2) ──────────────────────────────────────
# The web client subscribes to broadcast channels pushed by the Edge Function
# event-listener. Both vars required for realtime to flip on; otherwise the
# adapter falls back to Socket.IO against NEXT_PUBLIC_WS_URL.
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key from Supabase dashboard → Project Settings → API>

# Chain config exposed to the browser (for InterwovenKit + tx signing).
NEXT_PUBLIC_CHAIN_ID=ori-1
NEXT_PUBLIC_RPC_URL=https://<your-rollup-rpc>
NEXT_PUBLIC_REST_URL=https://<your-rollup-rest>
NEXT_PUBLIC_MODULE_ADDRESS=0x05dd0c60873d4d93658d5144fd0615bcfa43a53a

# Optional: the agent's signing address, used by the /today page's agent
# banner. Leave blank until Shipment 2 deploys MCP.
# NEXT_PUBLIC_MCP_SIGNER_ADDRESS=init1...
