{
  "name": "@ori/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm -F @ori/event-decoder build && prisma generate --schema=./prisma/schema.prisma && tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint via root'",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@cosmjs/amino": "^0.33.1",
    "@cosmjs/encoding": "^0.33.1",
    "@cosmjs/proto-signing": "^0.33.1",
    "@cosmjs/stargate": "^0.33.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.2",
    "@initia/initia.js": "^1.0.21",
    "@ori/event-decoder": "workspace:*",
    "@ori/shared-types": "workspace:*",
    "@prisma/client": "^6.1.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.0.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "bech32": "^2.0.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.16.0",
    "fastify": "^5.2.0",
    "graphile-worker": "^0.16.6",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "libsodium-wrappers-sumo": "^0.7.15",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.1.0",
    "socket.io": "^4.8.1",
    "typescript": "^5.7.0",
    "uuid": "^11.0.3",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
