; pnpm config for this workspace.
;
; production=false forces pnpm to install devDependencies even when
; NODE_ENV=production. Vercel sets NODE_ENV=production globally (for the
; function runtime) but we still need devDeps at BUILD time — tsc,
; @types/*, prisma CLI, etc. This flag keeps every workspace build green
; without having to chase @types packages into dependencies one-by-one.
production=false

; Keep peer-dep warnings non-fatal (we have a few version spreads in
; the InterwovenKit dep tree that are harmless).
strict-peer-dependencies=false
